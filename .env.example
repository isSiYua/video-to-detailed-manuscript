# Text model (OpenAI-compatible Chat Completions)
VTM_LLM_API_KEY=<text-model-api-key>
VTM_LLM_BASE_URL=https://api.deepseek.com
VTM_LLM_MODEL=deepseek-v4-flash

# Optional vision model
VTM_VISION_API_KEY=<vision-model-api-key>
VTM_VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VTM_VISION_MODEL=qwen3-vl-flash
VTM_MAX_VISION_FRAMES=60

# Storage and image quality
VTM_VAULT=/home/hermes/ObsidianVault
VTM_STATE_DIR=/home/hermes/.local/share/video-manuscript
VTM_TIMEZONE=Asia/Shanghai
VTM_VISUAL_HEIGHT=720
VTM_FINAL_VISUAL_HEIGHT=1080

# Optional Bilibili login state. Keep the real value in a protected server
# environment file, never in this repository.
BILIBILI_COOKIE=<optional-cookie-header>
